{% extends 'base.html.twig' %}

{% block title %}Mes commandes{% endblock %}

{% block body %}
<div class="container py-5">

    <h1 class="mb-4" style="color: var(--jaune)">
        <i class="bi bi-list-ul"></i> Mes commandes
    </h1>

    {% if orders is empty %}
        <div class="alert alert-info">
            <i class="bi bi-inbox"></i> Vous n'avez pas encore de commandes.
            <a href="{{ path('app_product_index') }}" class="alert-link">
                Voir les produits
            </a>
        </div>
    {% else %}
        {% for order in orders %}
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-receipt"></i> Commande #{{ order.id }}
                </h5>
                <span class="badge" style="background-color: var(--violet)">
                    {{ order.status }}
                </span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <p><strong>Date :</strong>
                            {{ order.createdAt|date('d/m/Y à H:i') }}
                        </p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Nombre d'articles :</strong>
                            {{ order.orderItems|length }}
                        </p>
                    </div>
                    <div class="col-md-4">
                        <p><strong>Total :</strong>
                            <span style="color: var(--jaune)" class="fw-bold">
                                {{ order.total|number_format(2, ',', ' ') }} €
                            </span>
                        </p>
                    </div>
                </div>

                <table class="table table-dark table-bordered mt-2">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th>Prix</th>
                            <th>Quantité</th>
                            <th>Sous-total</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in order.orderItems %}
                        <tr>
                            <td>{{ item.product.name }}</td>
                            <td>{{ item.price }} €</td>
                            <td>{{ item.quantity }}</td>
                            <td>{{ (item.price * item.quantity)|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endfor %}
    {% endif %}

    <div class="mt-3">
        <a href="{{ path('app_product_index') }}" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Continuer mes achats
        </a>
    </div>

</div>
{% endblock %}