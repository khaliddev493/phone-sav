{% extends 'base.html.twig' %}

{% block title %}Commande confirmée{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="text-center mb-5">
        <i class="bi bi-check-circle-fill" style="font-size: 5rem; color: var(--jaune)"></i>
        <h1 class="mt-3" style="color: var(--jaune)">Commande confirmée !</h1>
        <p class="text-muted">Merci pour votre commande numéro #{{ order.id }}</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-receipt"></i> Récapitulatif de la commande
                    </h5>
                </div>
                <div class="card-body">
                    <table class="table table-dark table-bordered">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>Prix unitaire</th>
                                <th>Quantité</th>
                                <th>Sous-total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in order.orderItems %}
                            <tr>
                                <td>{{ item.product.name }}</td>
                                <td>{{ item.price }} €</td>
                                <td>{{ item.quantity }}</td>
                                <td>{{ (item.price * item.quantity)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Total :</td>
                                <td style="color: var(--jaune)" class="fw-bold">
                                    {{ order.total|number_format(2, ',', ' ') }} €
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <p><strong>Statut :</strong>
                                <span class="badge" style="background-color: var(--violet)">
                                    {{ order.status }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Date :</strong>
                                {{ order.createdAt|date('d/m/Y à H:i') }}
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a href="{{ path('app_order_list') }}" class="btn btn-primary">
                    <i class="bi bi-list-ul"></i> Mes commandes
                </a>
                <a href="{{ path('app_product_index') }}" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left"></i> Continuer mes achats
                </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}