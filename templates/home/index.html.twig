{% extends 'base.html.twig' %}

{% block title %}PhoneShop - Accueil{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/home/index.css') }}">
{% endblock %}

{% block body %}

    {# ===== HERO FLASH BANNER ===== #}
    <section class="hero-slider">

        {# Slide 1 - iPhone 16 #}
        <div class="slide slide-iphone active">
            <div class="slide-content">
                <span class="badge-flash">⚡ Offre Flash</span>
                <p class="slide-brand">Apple</p>
                <h1 class="slide-title">iPhone 16</h1>
                <p class="slide-desc">
                    Puce A18 · Dynamic Island · Appareil photo 48 MP<br>
                    Neuf · Garantie 2 ans · 256 Go
                </p>
                <div class="price-block">
                    <span class="price-old">1 259 €</span>
                    <span class="price-new">1 019 €</span>
                </div>
                <a href="{{ path('app_product_index', {'q': 'iPhone 16 Pro'}) }}" class="btn-slide">
                    Profiter de l'offre →
                </a>
            </div>
            <div class="slide-image">
                <img src="{{ asset('images/slides/iphone16.jpg') }}" alt="iPhone 16 256Go">
            </div>
        </div>

        {# Slide 2 - Samsung S24 Ultra #}
        <div class="slide slide-samsung">
            <div class="slide-content">
                <span class="badge-flash">⚡ Offre Flash</span>
                <p class="slide-brand">Samsung</p>
                <h1 class="slide-title">Galaxy S24 Ultra</h1>
                <p class="slide-desc">
                    256 Go · Caméra 12 mégapixels · S Pen intégré<br>
                    Neuf · Garantie 2 ans
                </p>
                <div class="price-block">
                    <span class="price-old">789 €</span>
                    <span class="price-new">659 €</span>
                </div>
                <a href="{{ path('app_product_index', {'q': 'Samsung S24 Ultra'}) }}" class="btn-slide">
                    Profiter de l'offre →
                </a>
            </div>
            <div class="slide-image">
                <img src="{{ asset('images/slides/samsung-s24-ultra.jpg') }}" alt="Samsung Galaxy S24 Ultra 256Go">
            </div>
        </div>

        {# Slide 3 - Sauvetage GSM #}
        <div class="slide slide-repair">
            <div class="slide-content">
                <span class="badge-flash" style="background:#ff6a00;color:#fff;">🔧 Promotion Réparation</span>
                <p class="slide-brand">Service</p>
                <h1 class="slide-title">Sauvetage<br>GSM</h1>
                <p class="slide-desc">
                    Remplacement écran + batterie ?<br>
                    La batterie à
                    <strong style="color:#f5c518;">-50%</strong>
                    · Réparation en
                    <strong>1 heure</strong>
                </p>
                <div class="price-block">
                    <span class="promo-tag">ÉCRAN + BATTERIE</span>
                    <span class="promo-discount">-50% batterie</span>
                </div>
                <a href="{{ path('app_sauvetage') }}" class="btn-slide btn-slide-repair">
                    En profiter maintenant →
                </a>
            </div>
            <div class="slide-image slide-image-repair">
                <div class="repair-visual">
                    <div class="repair-phone">📱</div>
                    <div class="repair-icons">
                        <div class="repair-icon">🔧</div>
                        <div class="repair-icon">🔋</div>
                        <div class="repair-icon">📺</div>
                    </div>
                    <div class="repair-badge-big">-50%</div>
                </div>
            </div>
        </div>

        {# Indicateurs #}
        <div class="slider-dots">
            <span class="dot active" onclick="goToSlide(0)"></span>
            <span class="dot" onclick="goToSlide(1)"></span>
            <span class="dot" onclick="goToSlide(2)"></span>
        </div>

        {# Barre de progression #}
        <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
        </div>

    </section>

    {# ===== CATEGORIES ===== #}
    <section class="py-5" style="background-color: var(--purple-light);">
        <div class="container">
            <h2 class="text-center mb-4 text-white">Nos Catégories</h2>

            {% set categoryIcons = {
                'Téléphones neufs':    'bi-phone',
                'Câbles':              'bi-usb-c',
                'Chargeurs':           'bi-plug-fill',
                'Coques & Protection': 'bi-shield-fill',
                'Batteries externes':  'bi-battery-full',
                'Verres Trempés':      'bi-phone-landscape'
            } %}

            <div class="row g-3">
                {% for category in categories|slice(0, 8) %}
                    <div class="col-6 col-md-3">
                        <a href="{{ path('app_product_index', {'cat': category.id}) }}" class="text-decoration-none">
                            <div class="card h-100 text-center shadow-sm"
                                 style="transition: transform 0.2s;"
                                 onmouseover="this.style.transform='translateY(-4px)'"
                                 onmouseout="this.style.transform='translateY(0)'">
                                <div class="card-body py-4">
                                    <i class="bi {{ categoryIcons[category.name] ?? 'bi-grid' }} fs-1" style="color: #f5c518;"></i>
                                    <p class="card-text mt-2 fw-semibold text-white">
                                        {{ category.name }}
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# ===== PRODUITS ===== #}
    <section class="py-5" style="background-color: var(--main-purple);">
        <div class="container">
            <h2 class="text-center mb-4">Nouveautés</h2>

            <div class="row g-4">
                {% for product in products %}
                    <div class="col-6 col-md-3">
                        <div class="card h-100 shadow-sm" style="overflow:hidden; border-radius:10px;">

                            <div style="height:180px; background:#1A1F3A; overflow:hidden;">
                                <img src="{{ asset(product.image ? 'images/produits/' ~ product.image : 'images/produits/default.jpg') }}"
                                     alt="{{ product.name }}"
                                     style="width:100%; height:180px; object-fit:cover;">
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title">{{ product.name }}</h6>
                                <p class="text-muted small">{{ product.brand }}</p>
                                <p class="fw-bold mt-auto">{{ product.price }} €</p>
                                <a href="{{ path('app_product_show', {'id': product.id}) }}"
                                   class="btn btn-outline-primary btn-sm mt-2">
                                    Voir le produit
                                </a>
                            </div>

                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="text-center mt-4">
                <a href="{{ path('app_product_index') }}" class="btn btn-primary btn-lg">
                    Voir tous les produits
                </a>
            </div>
        </div>
    </section>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/home/slider.js') }}"></script>
{% endblock %}