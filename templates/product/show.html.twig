{% extends 'base.html.twig' %}

{% block title %}{{ produit.name }}{% endblock %}

{% block body %}
<div class="container py-5">

    <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left"></i> Retour aux produits
    </a>

    <div class="row">

        <div class="col-md-5 text-center">
            <div class="product-img rounded" style="height:400px; width:100%;">
                <span style="font-size:24px;">{{ produit.brand }}</span>
            </div>
        </div>

        <div class="col-md-7">
            <h1 class="fw-bold">{{ produit.name }}</h1>
            <p class="text-muted">Marque : <strong>{{ produit.brand }}</strong></p>
            <p class="text-muted">Catégorie : <strong>{{ produit.category.name }}</strong></p>
            <p class="text-muted">{{ produit.description }}</p>
            <h2 style="color: var(--jaune)" class="fw-bold my-3">{{ produit.price }} €</h2>

            {% if produit.stock > 0 %}
                <p class="text-success">
                    <i class="bi bi-check-circle"></i> En stock ({{ produit.stock }} disponibles)
                </p>
            {% else %}
                <p class="text-danger">
                    <i class="bi bi-x-circle"></i> Rupture de stock
                </p>
            {% endif %}

            <a href="{{ path('app_cart_add', {'id': produit.id}) }}" class="btn btn-primary btn-lg mt-3">
                <i class="bi bi-cart-plus"></i> Ajouter au panier
            </a>
        </div>

    </div>
</div>
{% endblock %}