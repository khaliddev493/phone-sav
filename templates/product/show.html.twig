{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<div class="container py-5">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_home') }}">Accueil</a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_product_index') }}">Produits</a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_product_index', {'cat': product.category.id}) }}">
                    {{ product.category.name }}
                </a>
            </li>
            <li class="breadcrumb-item active">{{ product.name }}</li>
        </ol>
    </nav>

    <div class="row g-5">

        {# IMAGE #}
        <div class="col-md-5 text-center">
            <img src="{{ asset(product.image ? 'images/produits/' ~ product.image : 'images/produits/default.jpg') }}"
                 alt="{{ product.name }}"
                 class="img-fluid rounded shadow"
                 style="max-height:400px; object-fit:contain; background:#fff;">
        </div>

        {# INFOS #}
        <div class="col-md-7">
            <p class="text-muted mb-1">{{ product.brand }}</p>
            <h1 class="h2 fw-bold mb-2">{{ product.name }}</h1>
            <p class="text-muted small mb-3">Catégorie : {{ product.category.name }}</p>

            <p class="fs-2 fw-bold text-primary mb-4">{{ product.price }} €</p>

            <p class="mb-4">{{ product.description }}</p>

            <div class="d-flex gap-2 mt-3">

                {% if product.stock > 0 %}
                    <a href="{{ path('app_cart_add', {'id': product.id}) }}"
                       class="btn btn-primary btn-lg">
                        <i class="bi bi-cart-plus"></i> Ajouter au panier
                    </a>
                {% endif %}

                <a href="{{ path('app_product_index', {'cat': product.category.id}) }}"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Retour à la catégorie
                </a>

            </div>{# fin d-flex #}
        </div>{# fin col-md-7 #}
    </div>{# fin row #}
</div>{# fin container #}

{% endblock %}